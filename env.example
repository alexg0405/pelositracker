# Optional paid sportsbook feed. Polymarket discovery and market data need no key.
THE_ODDS_API_KEY=
# Keep this below MAX_DATA_AGE_SECONDS; shorter polling uses more API credits.
ODDS_POLL_SECONDS=45
ODDS_REGIONS=us
ODDS_MARKETS=h2h,spreads,totals
ODDS_BOOKMAKERS=
ODDS_PLAYER_MARKETS=

# Disabled unless you have independently validated and are authorized to use
# these undocumented provider contracts. No shared credentials are shipped.
ENABLE_ACTION_NETWORK=false
ENABLE_PINNACLE_GUEST=false
PINNACLE_GUEST_API_KEY=

# Independent sport models remain display-only until a versioned out-of-sample
# validation artifact is installed for the exact sport/market combination.
ENABLE_INDEPENDENT_MODELS=false
# Separately reviewed exact-segment registry; the flag alone does nothing.
INDEPENDENT_MODEL_ARTIFACT=
# Path to a versioned, out-of-sample calibration JSON. No artifact is shipped;
# without one every recommendation remains WATCH/display-only.
CALIBRATION_ARTIFACT=

# Global engine floors run before bot-specific strategy checks. Keep these at
# zero so paper-bot strategies can enforce their own thresholds.
SIGNAL_CONFIDENCE_THRESHOLD=0
SIGNAL_EDGE_THRESHOLD=0
MAX_DATA_AGE_SECONDS=120
SIGNAL_KELLY_FRACTION=0.25

# Opt-in paper-harness override. When true, bots may trade signals the engine
# holds at WATCH *solely* because no validated calibration artifact is installed.
# The edge used is the uncalibrated gross consensus gap; every other gate still
# applies (>=2 independent references, clean full-depth fill, edge above floor),
# so single-source markets (e.g. Polymarket-only tennis/esports) still never
# trade. Leave false for validated-only behavior.
PAPER_ALLOW_UNCALIBRATED=false

# Opt-in independent in-play tennis model. When true, tennis moneylines get a
# real win probability derived from the live set/game score, anchored to the
# market price, inverted from the current price + live score at the first
# observation (so games joined in progress still trade). Bots trade the edge of
# that model vs the executable price, so tennis can trade a genuine edge
# despite having no reference-book feed. Serve-neutral, best-of-three by default.
ENABLE_TENNIS_MODEL=false

# Opt-in independent in-play model for lead/clock sports (basketball, football,
# hockey: NBA/WNBA/NCAAB/NFL/NCAAF/NHL). Win probability from the live lead and
# game clock (Brownian-margin model), anchored to the market's pre-match price.
# Overtime and unsupported leagues are skipped. Anchored to the market at the
# first observation (games joined in progress still trade), like the tennis model.
ENABLE_LEAD_MODEL=false

# Opt-in independent in-play model for soccer (EPL/MLS). Poisson goals model:
# the 1X2 price is inverted to each side's scoring rate at the first observation
# (games joined in progress still trade), then the live score and clock give
# home/draw/away result probabilities. Added time / extra time is skipped.
# Restricted to moneyline/1X2 selections. (Soccer market labels here are
# unverified against live data.)
ENABLE_SOCCER_MODEL=false

# Uncertainty-aware trade gate for model-backed bets (e.g. the tennis model):
# require the edge to clear its floor at the lower confidence bound
# (edge - z * model_sigma), not on the mean. Higher z = more conservative;
# 0 disables (mean-edge only). The tennis model's sigma narrows as the match
# resolves, so early-match bets need a larger raw edge to qualify.
PAPER_EDGE_UNCERTAINTY_Z=1.0

# Latency-aware repricing for in-play model bets. The model's uncertainty is
# widened for the execution window = how stale the score is + this budget
# (feed + compute + network + venue delay, seconds), so a stale/fast-moving
# state raises the edge bar. A score older than PAPER_MAX_STATE_AGE_SECONDS is
# considered too stale to price a realistic fill and is skipped.
PAPER_LATENCY_BUDGET_SECONDS=8.0
PAPER_MAX_STATE_AGE_SECONDS=30.0

# Joint-outcome (portfolio) Kelly sizing. When true, an account's simultaneous
# bets are sized together over their correlation groups (maximizing expected log
# wealth) instead of each at its own Kelly: positively correlated bets share one
# risk budget, independent bets get a little more total. Never exceeds a bet's
# own exposure cap. Off keeps the existing per-position sizing.
PAPER_PORTFOLIO_KELLY=false

# Fake-money paper fills are not real orders, so by default Polymarket's
# region-restriction flag does NOT block them. This is required for anything to
# trade from a restricted host region (e.g. the US), where Polymarket marks every
# event restricted. Set false to honor the flag and refuse paper fills on
# restricted markets.
PAPER_IGNORE_REGION_RESTRICTION=true

# Hide region-restricted events from discovery/auto-monitor/manual-add. Off by
# default: from a restricted host region every event is restricted, so excluding
# would hide everything. Only useful from an unrestricted region.
EXCLUDE_RESTRICTED_EVENTS=false

# Optional PostgreSQL DSN for all persistent stores. When blank, local SQLite
# uses LEDGER_DB for positions/accounts/monitor state and HISTORY_DB for quotes.
DATABASE_URL=
LEDGER_DB=ledger.db
HISTORY_DB=history.db
# Age cap for the decision-audit log (decision_marks). Old rows are pruned so a
# small managed database (e.g. a 500 MB Supabase free tier) cannot fill up. The
# large per-decision input snapshot is stored only for actual PAPER_BET rows.
DECISION_MARKS_RETENTION_DAYS=7
# Optional separate SQLite file for tracked events and auto-monitor settings.
# STATE_DB=state.db

# Change these before exposing the app outside your machine.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
APP_ENV=development
WEB_CONCURRENCY=1

# Comma-separated HTTPS webhook host allowlist. Private/loopback DNS results and
# redirects are rejected even for an allowlisted hostname.
WEBHOOK_ALLOWED_HOSTS=discord.com,hooks.slack.com
